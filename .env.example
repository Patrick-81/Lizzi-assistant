# Répertoire centralisé des modèles LLM
MODELS_DIR=$HOME/.var/app/llama-server/models

# Configuration LLM (llama.cpp)
LLM_HOST=http://localhost:11434
MODEL_NAME=mistral-7b-instruct

# Configuration Embeddings (llama.cpp sur port séparé)
EMBEDDING_HOST=http://localhost:11435
EMBEDDING_MODEL=jina-embeddings-v2-small-en

# Taille du contexte LLM (tokens)
CTX_SIZE=4096

# SearXNG (recherche web locale)
SEARXNG_URL=http://localhost:8006

# Port du serveur
PORT=3001
